# ── Supabase (same project the Flutter app uses) ────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# pg-boss needs a SESSION-mode Postgres connection (direct :5432, NOT the :6543
# transaction pooler) so it can use LISTEN/NOTIFY + advisory locks.
# Dashboard → Project Settings → Database → Connection string → "Session".
SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Scraper ─────────────────────────────────────────────────────────────────
# false = run a real (non-headless) Chromium under Xvfb (best Cloudflare pass
# rate). The Docker image sets this to false and wraps the process in xvfb-run.
# Set true for local headless runs without a display.
HEADLESS=true
# Optional residential/TW proxy used ONLY if Cloudflare Turnstile blocks the
# datacenter IP (see README risk #1). e.g. http://user:pass@host:port
PROXY_URL=

# ── Queue / scheduler ───────────────────────────────────────────────────────
# How many user syncs run in parallel (each opens a browser → keep small).
SYNC_CONCURRENCY=2
# How often the scheduler scans carrier_config for due users (ms).
SCHEDULER_INTERVAL_MS=60000
# Hard deadline for one sync job (scrape + ingest), in seconds. Bump for large
# accounts whose multi-page export takes longer.
SYNC_JOB_EXPIRE_SECONDS=600

# ── Rate limiting ───────────────────────────────────────────────────────────
# Min seconds between a user's manual "Sync now" requests (429 below this).
SYNC_COOLDOWN_SECONDS=60
# Min milliseconds between portal logins across ALL users (politeness/anti-bot).
PORTAL_MIN_GAP_MS=3000
# Generic per-IP HTTP request ceiling and its window.
HTTP_RATE_MAX=60
HTTP_RATE_WINDOW_MS=60000

# ── Sync window (incremental date-range scrape) ─────────────────────────────
# Re-fetch this many days before the last successful sync (overlap; dedupe-safe).
SYNC_OVERLAP_DAYS=3
# First-ever sync (no prior success) looks back this many days.
SYNC_LOOKBACK_DAYS=60

# ── HTTP ────────────────────────────────────────────────────────────────────
PORT=8080
