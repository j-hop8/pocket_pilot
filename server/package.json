{
  "name": "pocketpilot-server",
  "version": "1.0.0",
  "private": true,
  "description": "PocketPilot backend — carrier e-invoice sync (Playwright scrape + Tesseract OCR), job queue, scheduler.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "spike": "tsx src/spike.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "fastify": "^4.28.1",
    "pg-boss": "^10.1.5",
    "playwright": "1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
